<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:show_buffering="when_playing"
        app:use_controller="false"
        app:resize_mode="zoom" />

    <!-- Right-side interaction buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="12dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/btn_like"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_favorite"
            android:contentDescription="like" />
        <TextView
            android:id="@+id/feed_like_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="11sp" />

        <ImageView
            android:id="@+id/btn_comment"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="20dp"
            android:padding="8dp"
            android:src="@drawable/ic_comment"
            android:contentDescription="comment" />
        <TextView
            android:id="@+id/feed_comment_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="11sp" />

        <ImageView
            android:id="@+id/btn_collect"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="20dp"
            android:padding="8dp"
            android:src="@drawable/ic_bookmark"
            android:contentDescription="collect" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/collect"
            android:textColor="@color/white"
            android:textSize="11sp" />

        <ImageView
            android:id="@+id/btn_share"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="20dp"
            android:padding="8dp"
            android:src="@drawable/ic_share"
            android:contentDescription="share" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/share"
            android:textColor="@color/white"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Bottom left info area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="60dp"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp">

            <TextView
                android:id="@+id/feed_ranking_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:background="@drawable/bg_player_ranking_badge"
                android:includeFontPadding="false"
                android:letterSpacing="0.02"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:textColor="@color/player_ranking_chip_text"
                android:textSize="12sp"
                android:textStyle="bold"
                android:shadowColor="@color/desc_inline_action_shadow"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="3"
                android:visibility="gone" />

            <!-- Drama title -->
            <TextView
                android:id="@+id/feed_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:id="@+id/feed_tag_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fadingEdgeLength="12dp"
                android:fillViewport="false"
                android:overScrollMode="never"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/feed_tag_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <!-- Drama description -->
            <TextView
                android:id="@+id/feed_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp" />

            <!-- View episodes button -->
            <TextView
                android:id="@+id/btn_view_episodes"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_feed_episodes_btn"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Seekable progress bar -->
        <SeekBar
            android:id="@+id/feed_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-6dp"
            android:max="1000"
            android:minHeight="3dp"
            android:maxHeight="3dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:progressDrawable="@drawable/bg_feed_progress_track"
            android:thumb="@null"
            android:splitTrack="false" />
    </LinearLayout>
</FrameLayout>
