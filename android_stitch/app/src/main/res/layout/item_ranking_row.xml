<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:layout_marginHorizontal="@dimen/spacing_lg"
    android:layout_marginBottom="@dimen/spacing_sm"
    android:orientation="horizontal"
    android:padding="@dimen/spacing_md">

    <TextView
        android:id="@+id/rank_number"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="@dimen/text_headline"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/rank_cover"
        android:layout_width="56dp"
        android:layout_height="72dp"
        android:layout_marginStart="@dimen/spacing_sm"
        android:background="@color/surface_container_high"
        android:scaleType="centerCrop"
        android:contentDescription="cover" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/rank_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/on_surface"
            android:textSize="@dimen/text_body"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/rank_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/on_surface_variant"
            android:textSize="@dimen/text_body_sm" />

        <TextView
            android:id="@+id/rank_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/on_surface_variant"
            android:textSize="@dimen/text_caption" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/rank_heat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tag"
                android:textColor="@color/primary_light"
                android:textSize="@dimen/text_caption" />

            <TextView
                android:id="@+id/rank_likes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_tag"
                android:textColor="@color/primary_light"
                android:textSize="@dimen/text_caption" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
