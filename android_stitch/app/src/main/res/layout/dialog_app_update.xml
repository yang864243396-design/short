<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/app_update_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:clickable="true"
    android:focusable="true">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/app_update_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="版本更新"
                android:textColor="#DE000000"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/app_update_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#99000000"
                android:textSize="14sp" />

            <ScrollView
                android:id="@+id/app_update_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:maxHeight="180dp"
                android:scrollbars="vertical">

                <TextView
                    android:id="@+id/app_update_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingMultiplier="1.15"
                    android:textColor="#DE000000"
                    android:textSize="15sp" />
            </ScrollView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/app_update_btn_ok"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="立即更新" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/app_update_btn_cancel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="关闭"
                android:visibility="gone" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
