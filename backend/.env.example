# 复制为 backend/.env（已 gitignore）或在 systemd / Docker 中注入同名环境变量
# ============ 运行模式 ============
GIN_MODE=release
# 监听端口（二选一；云厂商常只给 PORT）
HTTP_PORT=8080
# PORT=8080

# ============ MySQL ============
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=short

# ============ Redis ============
REDIS_ADDR=127.0.0.1:6379
# 无密码：写 REDIS_PASSWORD= 或整行删掉；勿在键后留空格。未写 REDIS_PASSWORD 时程序会用本地默认 123123
REDIS_PASSWORD=
REDIS_DB=0

# ============ JWT（生产务必改为长随机串）============
JWT_SECRET=change-me-to-long-random-string
JWT_EXPIRE_HOURS=72

# 用户充值：为 true 时 App 可调用 POST /recharge-orders/:id/simulate-pay 模拟到账（仅测试；生产对接支付后应关闭）
USER_RECHARGE_SIMULATE=false

# ============ SMTP（邮箱注册验证码）============
# 需在服务器 backend/.env 或环境中配置完整五项，否则接口返回「邮件服务未配置」或「发送失败」。
# SMTP_FROM 一般为发信地址，多数服务商要求与 SMTP_USER 一致或为其别名。
# 端口：465=SSL；587=STARTTLS（QQ/163/企业邮常见，云主机若封 465 可改 587）。
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
